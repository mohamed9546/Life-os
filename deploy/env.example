# ============================================================
# Life OS — production env file
# Deploy location on VM: /opt/life-os/env  (chmod 600)
# Replace every REPLACE_ME below with real values, then:
#   sudo systemctl restart life-os
# ============================================================

NODE_ENV=production
PORT=8080

# --- Supabase (public values also baked into the Dockerfile for client bundle,
#     but we set them again here so server-side reads work) ---
NEXT_PUBLIC_SUPABASE_URL=https://syzjsukrnzlnbyqbttja.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_AoWyEf9yL7m5MFTSDeTGkg_XqOAPbUA
SUPABASE_SERVICE_ROLE_KEY=REPLACE_ME

# --- Gemini (Google AI) ---
GEMINI_API_KEY=REPLACE_ME

# --- Default owner user id (single-tenant Life OS) ---
# The Supabase auth user id that owns pipeline/worker writes when no session is present.
# Must be a real UUID from auth.users (required for raw_jobs/jobs FK).
LIFE_OS_DEFAULT_USER_ID=aa56d89e-f36e-4287-a958-476a282bf64e
LIFE_OS_DEFAULT_USER_EMAIL=mohamed.magdy.tc@gmail.com

# --- Optional: admin gate for the career beta ---
# Comma-separated list of email addresses allowed into /career routes
CAREER_BETA_ADMIN_EMAILS=mohamed.magdy.tc@gmail.com

# --- Optional: Firecrawl (only if you actually run a Firecrawl instance) ---
# FIRECRAWL_BASE_URL=https://api.firecrawl.com
# FIRECRAWL_API_KEY=

# --- Optional: Ollama (only if you run Ollama locally on the VM) ---
# OLLAMA_BASE_URL=http://localhost:11434
# OLLAMA_MODEL=llama3.1
