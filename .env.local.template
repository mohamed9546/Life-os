# Life OS local-only environment
LIFE_OS_LOCAL_ONLY=true
NEXT_PUBLIC_LIFE_OS_LOCAL_ONLY=true
LIFE_OS_DEFAULT_USER_ID=preview-user
LIFE_OS_DEFAULT_USER_EMAIL=preview@careerbeta.local
CAREER_BETA_ADMIN_EMAILS=preview@careerbeta.local

# Ollama native runtime for the Next.js AI client
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_MODEL=qwen3.5:2b
LOCAL_AI_COMPAT_MODE=ollama

# Python sidecar used by /api/ai/parse-job and /api/ai/evaluate-job
USE_PYTHON_AI=true
PYTHON_AI_URL=http://127.0.0.1:8800
PYTHON_AI_AUTH=none

# Python sidecar talks to Ollama through its OpenAI-compatible endpoint
LLM_URL=http://127.0.0.1:11434/v1
LLM_MODEL=qwen3.5:2b
LLM_JSON_MODE=false

# Optional source adapter keys
ADZUNA_APP_ID=
ADZUNA_APP_KEY=
REED_API_KEY=
THEMUSE_API_KEY=
JOOBLE_API_KEY=
FINDWORK_API_KEY=
SERP_API_KEY=
APOLLO_API_KEY=
